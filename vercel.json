{
  "version": 2,
  "builds": [
    {
      "src": "kpi_project/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": { "distDir": "staticfiles" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "kpi_project/wsgi.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/auto-close-kpi",
      "schedule": "0 0 5 * *"
    },
    {
      "path": "/api/cron/reminder-email",
      "schedule": "0 0 3 * *"
    }
  ]
}
